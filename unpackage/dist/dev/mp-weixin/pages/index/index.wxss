/* 文章场景相关 */
.page-home {
  background-color: #fafaf3;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}

/* 顶部导航 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  padding: 0 48rpx;
  padding-top: var(--status-bar-height);
  background-color: rgba(250, 250, 243, 0.8);
  -webkit-backdrop-filter: blur(10px);
          backdrop-filter: blur(10px);
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
}
.nav-bar .nav-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.nav-bar .nav-left .nav-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #4b6646;
  letter-spacing: -1rpx;
}
.main-content {
  flex: 1;
  padding-top: calc(120rpx + var(--status-bar-height));
}
.content-wrapper {
  padding: 0 48rpx;
}

/* 问候语 */
.greeting-section {
  margin-bottom: 60rpx;
}
.greeting-section .sub-greeting {
  font-size: 28rpx;
  color: #5f6056;
  margin-bottom: 8rpx;
  display: block;
}
.greeting-section .main-greeting {
  font-size: 48rpx;
  font-weight: bold;
  color: #30332c;
  display: block;
  letter-spacing: -1rpx;
}

/* 统计卡片 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
  margin-bottom: 80rpx;
}
.stats-grid .stats-card {
  background-color: #f4f4eb;
  padding: 32rpx;
  border-radius: 48rpx;
  min-height: 240rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
}
.stats-grid .stats-card .num-wrapper {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.stats-grid .stats-card .num-wrapper .card-num {
  font-size: 52rpx;
  font-weight: bold;
  color: #30332c;
}
.stats-grid .stats-card .num-wrapper .card-unit {
  font-size: 20rpx;
  color: #5f6056;
}
.stats-grid .stats-card .card-label {
  font-size: 20rpx;
  font-weight: 500;
  color: #5f6056;
}
.stats-grid .stats-card .card-deco {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  transform: scale(0.7);
}

/* 公用章节标题 */
.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 30rpx;
}
.section-header.space-between {
  justify-content: space-between;
  align-items: flex-end;
}
.section-header .section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #30332c;
}
.section-header .title-dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #ccebc2;
  border-radius: 50%;
}
.section-header .view-all {
  font-size: 22rpx;
  font-weight: 600;
  color: #4b6646;
}

/* 快捷操作 */
.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 80rpx;
}
.action-grid .action-btn {
  padding: 28rpx 32rpx;
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  transition: transform 0.2s;
}
.action-grid .action-btn:active {
  transform: scale(0.95);
}
.action-grid .action-btn .action-text {
  font-size: 26rpx;
  font-weight: 600;
}
.action-grid .action-btn.primary {
  background-color: #4b6646;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(75, 102, 70, 0.1);
}
.action-grid .action-btn.secondary {
  background-color: #f4f4eb;
  color: #30332c;
}

/* 最近收纳 */
.recent-scroll {
  width: 100%;
  white-space: nowrap;
  margin: 0 -48rpx;
  padding: 0 48rpx;
  box-sizing: border-box;
}
.recent-scroll .recent-list {
  display: inline-flex;
  gap: 24rpx;
  padding-bottom: 40rpx;
}
.recent-scroll .recent-card {
  width: 260rpx;
  background-color: #fff;
  border-radius: 32rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(95, 96, 86, 0.05);
}
.recent-scroll .recent-card .item-img {
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}
.recent-scroll .recent-card .item-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #30332c;
  display: block;
  margin-bottom: 4rpx;
}
.recent-scroll .recent-card .item-cost {
  font-size: 18rpx;
  color: #5f6056;
}
.empty-recent {
  padding: 40rpx 0;
  text-align: center;
  color: #5f6056;
  font-size: 24rpx;
}
.footer-spacer {
  height: 200rpx;
}