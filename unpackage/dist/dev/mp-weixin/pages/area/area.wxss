.page-area {
  background-color: #fafaf3;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}

/* 顶部导航 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  padding: 0 220rpx 0 48rpx;
  /* 增加右侧内边距，避开微信胶囊按钮 */
  padding-top: var(--status-bar-height);
  background-color: rgba(250, 250, 243, 0.8);
  -webkit-backdrop-filter: blur(10px);
          backdrop-filter: blur(10px);
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
}
.nav-bar .nav-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.nav-bar .nav-left .nav-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #4b6646;
  letter-spacing: -1rpx;
}
.main-content {
  flex: 1;
  padding-top: calc(120rpx + var(--status-bar-height));
}
.content-wrapper {
  padding: 0 48rpx;
}

/* 页面标题 & 添加按钮 */
.header-section {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 60rpx;
}
.header-section .sub-title {
  font-size: 24rpx;
  color: #5f6056;
  font-weight: 600;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 8rpx;
}
.header-section .main-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #30332c;
  display: block;
}
.header-section .add-area-btn {
  background-color: #4b6646;
  padding: 24rpx 40rpx;
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 20rpx rgba(75, 102, 70, 0.15);
}
.header-section .add-area-btn text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

/* 统计概览 */
.stats-overview {
  background-color: #f4f4eb;
  border-radius: 32rpx;
  padding: 40rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 60rpx;
}
.stats-overview .stats-item {
  text-align: center;
}
.stats-overview .stats-item .stats-label {
  font-size: 20rpx;
  color: #5f6056;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}
.stats-overview .stats-item .stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4b6646;
}
.stats-overview .divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(95, 96, 86, 0.1);
}

/* 区域网格 */
.area-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48rpx;
  padding-bottom: 40rpx;
}
.area-grid .area-card {
  background-color: #ffffff;
  height: 384rpx;
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  border: 1rpx solid rgba(177, 179, 168, 0.2);
  transition: all 0.3s;
}
.area-grid .area-card:nth-child(even) {
  transform: translateY(48rpx);
}
.area-grid .area-card:active {
  opacity: 0.8;
  transform: scale(0.98);
}
.area-grid .area-card .card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.area-grid .area-card .card-header .icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.area-grid .area-card .card-footer .area-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #30332c;
  display: block;
  margin-bottom: 8rpx;
}
.area-grid .area-card .card-footer .item-count {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.area-grid .area-card .card-footer .item-count .count-num {
  font-size: 24rpx;
  font-weight: bold;
  color: #4b6646;
}
.area-grid .area-card .card-footer .item-count .count-unit {
  font-size: 24rpx;
  color: #5f6056;
}

/* 底部装饰 */
.bottom-deco {
  margin-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.4;
}
.bottom-deco .deco-text {
  font-size: 20rpx;
  color: #5f6056;
  margin-top: 16rpx;
  letter-spacing: 4rpx;
  font-style: italic;
}
.footer-spacer {
  height: 240rpx;
}

/* 添加区域弹窗样式 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  -webkit-backdrop-filter: blur(4px);
          backdrop-filter: blur(4px);
}
.popup-content {
  width: 85%;
  background-color: #fafaf3;
  border-radius: 64rpx;
  padding: 48rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.1);
}
.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}
.popup-header .popup-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #30332c;
}
.popup-header .close-btn {
  padding: 8rpx;
}
.popup-body .form-item {
  margin-bottom: 40rpx;
}
.popup-body .form-item .label {
  font-size: 24rpx;
  font-weight: 600;
  color: #5f6056;
  margin-bottom: 16rpx;
  display: block;
}
.popup-body .form-item .input-field {
  background-color: #eeefe5;
  height: 100rpx;
  border-radius: 24rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #30332c;
}
.popup-body .color-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.popup-body .color-list .color-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}
.popup-body .color-list .color-dot:active {
  transform: scale(0.9);
}
.popup-body .color-list .color-dot.active {
  border: 4rpx solid #ccebc2;
}
.popup-body .color-list .color-dot .dot-inner {
  width: 24rpx;
  height: 24rpx;
  background-color: #fff;
  border-radius: 50%;
}
.popup-body .icon-selector-wrapper {
  background-color: #eeefe5;
  border-radius: 32rpx;
  padding: 12rpx;
}
.popup-body .icon-selector-wrapper .icon-list {
  display: flex;
  justify-content: space-between;
  padding: 8rpx;
}
.popup-body .icon-selector-wrapper .icon-list .icon-item {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  transition: background-color 0.2s;
}
.popup-body .icon-selector-wrapper .icon-list .icon-item.active {
  background-color: rgba(255, 255, 255, 0.6);
}
.popup-body .popup-actions {
  margin-top: 60rpx;
  display: flex;
  gap: 24rpx;
}
.popup-body .popup-actions .delete-popup-btn {
  flex: 1;
  height: 112rpx;
  background-color: rgba(167, 59, 33, 0.1);
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.popup-body .popup-actions .delete-popup-btn text {
  color: #a73b21;
  font-size: 28rpx;
  font-weight: bold;
}
.popup-body .popup-actions .save-popup-btn {
  flex: 2;
  height: 112rpx;
  background-color: #4b6646;
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 16rpx 32rpx rgba(75, 102, 70, 0.2);
}
.popup-body .popup-actions .save-popup-btn.is-edit {
  background: linear-gradient(to right, #4b6646, #3f5a3a);
}
.popup-body .popup-actions .save-popup-btn text {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}